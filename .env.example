# Groq AI Chat Configuration
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Groq Model Timeout (milliseconds)
# How long to wait for Groq API response before timing out
GROQ_MODEL_TIMEOUT_MS=30000

# Groq Retry Configuration
# Number of retry attempts when Groq API fails
GROQ_RETRY_MAX_ATTEMPTS=2

# Base delay between retries (milliseconds)
# Uses exponential backoff: delay = base * 2^(attempt-1)
GROQ_RETRY_BASE_MS=900

# Maximum delay between retries (milliseconds)
GROQ_RETRY_MAX_DELAY_MS=8000

# Netlify Configuration
# Your site name on Netlify (used for origin validation)
# Example: if your site is eef.netlify.app, use NETLIFY_SITE_NAME=eef
NETLIFY_SITE_NAME=your-site-name

# Server Configuration
# Port for the Express development server
PORT=5174

# Node Environment
# Options: development, production
NODE_ENV=development

# CORS Configuration (optional)
# Allowed origin for development
CORS_ORIGIN=http://localhost:5173
